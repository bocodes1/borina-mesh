# Anthropic API — OPTIONAL
# If set: uses API directly (pay-per-token).
# If unset: falls back to `claude` CLI subprocess (uses Claude Max subscription).
# On the Mac Mini, leave this blank — the `claude` CLI is already authenticated.
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=sqlite:///./borina.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Obsidian vault root — reports auto-copy here for cross-machine sync.
# The dashboard Files tab merges local reports/ with {vault}/reports/,
# so artifacts generated on either PC or Mac Mini show up on both.
# Mac Mini: /Users/clawd/.openclaw/workspace
# PC:       C:/Users/wenbo/OneDrive/Documents/remote
OBSIDIAN_VAULT_PATH=/Users/clawd/.openclaw/workspace
