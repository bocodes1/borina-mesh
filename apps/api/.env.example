# Anthropic API — OPTIONAL
# If set: uses API directly (pay-per-token).
# If unset: falls back to `claude` CLI subprocess (uses Claude Max subscription).
# On the Mac Mini, leave this blank — the `claude` CLI is already authenticated.
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=sqlite:///./borina.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Obsidian vault (for agent memory access)
OBSIDIAN_VAULT_PATH=/Users/clawd/.openclaw/workspace
